<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github-industreal" value="https://nuget.pkg.github.com/industREAL-tech/index.json" />
  </packageSources>
  <!-- industREAL.* packages come from the private GitHub Packages feed; everything else from nuget.org.
       Auth: run once (PAT needs read:packages scope):
       dotnet nuget add source "https://nuget.pkg.github.com/industREAL-tech/index.json" \
         --name github-industreal --username <github-user> \
         --password <PAT> --store-password-in-clear-text
       Do NOT commit credentials into this file. -->
  <packageSourceMapping>
    <packageSource key="github-industreal">
      <package pattern="industREAL.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
